#!/bin/sh
# flint pre-commit hook (non-blocking)
#
# Runs `flint check --hook-mode` against staged YAML files (or the whole repo
# if no YAMLs are staged). Diagnostics are printed but the commit is never
# blocked, even on errors.
#
# Installed by `flint hooks install`. To remove, run `flint hooks uninstall`
# or delete this file.

set -e

# Find a flint binary on PATH.
if ! command -v flint >/dev/null 2>&1; then
    echo "flint: pre-commit hook installed but 'flint' not found on PATH — skipping" >&2
    exit 0
fi

# Collect staged YAML files (added/modified/copied/renamed/typed-changed).
staged_yaml="$(git diff --cached --name-only --diff-filter=ACMRT \
    -- '*.yml' '*.yaml' 2>/dev/null || true)"

echo "flint: running pre-commit validation (warnings only, never blocks)"

if [ -n "$staged_yaml" ]; then
    # Lint each staged YAML file individually so the report is scoped.
    echo "$staged_yaml" | while IFS= read -r file; do
        [ -n "$file" ] || continue
        [ -f "$file" ] || continue
        flint check --hook-mode "$file" || true
    done
else
    # No staged YAMLs — fall back to the whole repo for a quick health check.
    flint check --hook-mode . || true
fi

# Always succeed: this hook is informational, not gating.
exit 0
